{
  "version": 2,
  "builds": [
    { "src": "api/*.js", "use": "@vercel/node" },
    { "src": "public/index.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/programme", "dest": "/api/programme.js" },
    { "src": "/api/participants", "dest": "/api/participants.js" },
    { "src": "/api/cotes", "dest": "/api/cotes.js" },
    { "src": "/(.*)", "dest": "/public/index.html" }
  ]
}
